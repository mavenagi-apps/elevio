# Maven platform credentials
MAVENAGI_APP_ID=elevio
MAVENAGI_APP_SECRET=

# Inngest (required for the async ETL pipeline)
# The Inngest SDK reads these automatically at runtime.
# For local dev, run the Inngest dev server (see e2e/docker-compose.e2e.yml)
# and these can be omitted. For production/Vercel, set them in the project env vars.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Elevio API credentials (passed as connector settings, not env vars)
# These are provided via the settings object at install time, but you can
# use them in tests by constructing a mockSettings object:
#
#   const mockSettings = {
#     key: "<your Elevio API key>",
#     token: "<your Elevio API token>",
#     helpCenterUrl: "https://your-company.elevio.help",
#   };
#
# To find these values:
#   key:            Elevio dashboard → Settings → API → API Key
#   token:          Elevio dashboard → Settings → API → API Token
#   helpCenterUrl:  The public URL of the customer's Elevio help center (optional, enables SOLN-63 URL fix)
