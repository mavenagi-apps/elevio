{
  "name": "@mavenagi/elevio",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint": "oxlint --type-aware --type-check --deny-warnings",
    "lint:fix": "oxlint --type-aware --type-check --deny-warnings --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "start": "next start",
    "test": "vitest run",
    "test:vitest": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:neve_record": "NEVE_RECORD=true pnpm run test:e2e",
    "postinstall": "husky",
    "deploy-app.beta": "./scripts/deploy-app-to-vercel.sh elevio"
  },
  "dependencies": {
    "@keyv/compress-gzip": "^2.0.3",
    "@keyv/redis": "^5.1.6",
    "@mavenagi/apps-core": "npm:@mavenagi/apps-core@latest",
    "@mavenagi/knowledge-converter": "^1.0.24",
    "bottleneck": "^2.19.5",
    "cacheable": "^2.3.2",
    "eld": "^1.0.1",
    "inngest": "^3.51.0",
    "keyv": "^5.6.0",
    "mavenagi": "1.2.6",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "redis": "^5.0.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@inngest/test": "0.1.9",
    "@mavenagi/apps-core-dev": "npm:@mavenagi/apps-core-dev@latest",
    "@types/node": "^25.2.1",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.3.1",
    "fetch-mock": "^12.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "2.12.7",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.11.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "5.1.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,tsx}": "oxlint --deny-warnings --fix",
    "*.{ts,tsx,json,css,md}": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": "^22.11.0"
  },
  "packageManager": "pnpm@10.3.0"
}
